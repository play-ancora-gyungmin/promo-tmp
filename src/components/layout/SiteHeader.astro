---
import type { LandingData } from '../../types/landing';
import Container from './Container.astro';
import FloatingHeaderController from '../ui/FloatingHeaderController.svelte';

export interface Props {
  brand: LandingData['brand'];
}

const { brand } = Astro.props;
const brandMonogram = Array.from((brand.teacherName || brand.brandName).replace(/\s+/g, ''))
  .slice(0, 2)
  .join('');
---

<header class="site-header" data-scroll-state="top">
  <FloatingHeaderController client:load selector=".site-header" />

  <Container class="site-header__inner">
    <div class="site-header__bar">
      <a class="site-brand" href="#hero" aria-label={`${brand.brandName} 상단으로 이동`}>
        <span class="site-brand__icon" aria-hidden="true">
          <span>{brandMonogram}</span>
        </span>

        <span class="site-brand__copy">
          <strong>{brand.brandName}</strong>
          <span>{brand.teacherName} {brand.subject}</span>
        </span>
      </a>

      <a class="site-header__cta" href="#contact">
        문의
      </a>
    </div>
  </Container>
</header>
