---
import { buildSeoMeta } from '../../lib/landing/buildSeoMeta';
import { resolveSections } from '../../lib/landing/resolveSectionOrder';
import { resolveThemeVariant } from '../../lib/landing/resolveThemeVariant';
import type { LandingData } from '../../types/landing';
import BaseLayout from './BaseLayout.astro';
import SiteFooter from './SiteFooter.astro';
import SiteHeader from './SiteHeader.astro';
import SlideDeckController from '../ui/SlideDeckController.svelte';

export interface Props {
  landing: LandingData;
}

const { landing } = Astro.props;
const seo = buildSeoMeta(landing);
const theme = resolveThemeVariant(landing.theme?.variant);
const brand = {
  teacherName: landing.brand?.teacherName ?? '',
  subject: landing.brand?.subject ?? '',
  brandName: landing.brand?.brandName ?? 'Dococo Landing Template',
  tagline: landing.brand?.tagline ?? '강사 랜딩 템플릿',
  logo: landing.brand?.logo
};
const sections = resolveSections(landing.sections, landing.enabledSections, landing.sectionOrder);
const heroSection = sections.find((section) => section.type === 'hero');
const contactSection = sections.find((section) => section.type === 'contact');
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  ogImage={seo.ogImage}
  bodyClass={`landing-body theme-${theme}`}
>
  <SiteHeader
    brand={brand}
    topHref={heroSection ? `#${heroSection.id}` : '#hero'}
    contactHref={contactSection ? `#${contactSection.id}` : '#contact'}
  />

  <main class="site-main landing-main">
    <SlideDeckController client:load selector="[data-slide-section]" />

    <div class="landing-deck">
      <slot />
    </div>
  </main>

  <SiteFooter brand={brand} />
</BaseLayout>
