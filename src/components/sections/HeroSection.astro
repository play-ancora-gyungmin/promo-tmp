---
import type { LandingData, LandingSectionConfig } from '../../types/landing';
import Container from '../layout/Container.astro';
import SectionShell from '../layout/SectionShell.astro';
import HeroImage from '../ui/HeroImage.astro';

export interface Props {
  section: LandingSectionConfig;
  landing: LandingData;
}

interface HeadlineSegment {
  text: string;
  highlight: boolean;
}

const highlightPattern = /\[\[(.+?)\]\]/g;

const parseHeadlineSegments = (line: string): HeadlineSegment[] => {
  const segments: HeadlineSegment[] = [];
  let lastIndex = 0;

  for (const match of line.matchAll(highlightPattern)) {
    const fullMatch = match[0];
    const highlightedText = match[1] ?? '';
    const matchIndex = match.index ?? 0;

    if (matchIndex > lastIndex) {
      segments.push({
        text: line.slice(lastIndex, matchIndex),
        highlight: false
      });
    }

    if (highlightedText) {
      segments.push({
        text: highlightedText,
        highlight: true
      });
    }

    lastIndex = matchIndex + fullMatch.length;
  }

  if (lastIndex < line.length) {
    segments.push({
      text: line.slice(lastIndex),
      highlight: false
    });
  }

  return segments.length ? segments : [{ text: line, highlight: false }];
};

const { section, landing } = Astro.props;
const brandName = landing.brand?.brandName ?? 'Dococo Landing Template';
const teacherName = landing.brand?.teacherName ?? '';
const headlineData = landing.hero?.headline;
const renderedHeadlineLines =
  typeof headlineData === 'object' && headlineData?.lines?.length
    ? headlineData.lines.filter(Boolean)
    : [typeof headlineData === 'string' && headlineData.trim() ? headlineData.trim() : brandName];
const leadHeadlinePrefix =
  typeof headlineData === 'object' ? headlineData.lead?.prefix?.trim() ?? '' : '';
const leadHeadlineEmphasis =
  typeof headlineData === 'object' ? headlineData.lead?.emphasis?.trim() ?? '' : '';
const renderedHeadlineSegments = renderedHeadlineLines.map((line) => parseHeadlineSegments(line));
const heroImage = landing.hero?.image;
const heroImageAspectRatio = heroImage ? heroImage.width / heroImage.height : undefined;
const imageAlt = teacherName ? `${teacherName} 강사 프로필 이미지` : `${brandName} 대표 이미지`;
---

<SectionShell
  id={section.id}
  kind={section.kind}
  class="hero-section"
  surfaceClass="hero-section__surface"
>
  <Container class="hero-section__container">
    <div class="hero-section__grid">
      <div class="hero-section__content">
        <div class="hero-section__headline-stack">
          <h1 class="hero-section__headline">
            {renderedHeadlineSegments.map((segments) => (
              <span class="hero-section__headline-line">
                {segments.map((segment) =>
                  segment.highlight ? (
                    <span class="hero-section__headline-highlight">{segment.text}</span>
                  ) : (
                    segment.text
                  )
                )}
              </span>
            ))}
          </h1>
          {leadHeadlinePrefix || leadHeadlineEmphasis ? (
            <p class="hero-section__headline hero-section__headline--lead-block">
              {leadHeadlinePrefix ? (
                <span class="hero-section__headline-line hero-section__headline-line--lead hero-section__headline-prefix">
                  {leadHeadlinePrefix}
                </span>
              ) : null}
              {leadHeadlineEmphasis ? (
                <span class="hero-section__headline-line hero-section__headline-line--lead hero-section__headline-emphasis">
                  {leadHeadlineEmphasis}
                </span>
              ) : null}
            </p>
          ) : null}
        </div>
      </div>

      <div
        class="hero-section__visual"
        aria-hidden={heroImage ? undefined : 'true'}
        style={heroImageAspectRatio ? `--hero-image-aspect-ratio:${heroImageAspectRatio};` : undefined}
      >
        <div class="hero-section__visual-glow"></div>
        <div class="hero-section__visual-frame">
          <HeroImage
            src={heroImage}
            alt={imageAlt}
            class="hero-section__portrait"
            sizes="(min-width: 1200px) 56rem, (min-width: 1025px) 48rem, 100vw"
          />
        </div>
      </div>
    </div>
  </Container>
</SectionShell>
