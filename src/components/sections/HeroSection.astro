---
import type { LandingData, LandingSectionConfig } from '../../types/landing';
import Container from '../layout/Container.astro';
import SectionShell from '../layout/SectionShell.astro';
import HeroImage from '../ui/HeroImage.astro';

export interface Props {
  section: LandingSectionConfig;
  landing: LandingData;
}

const { section, landing } = Astro.props;
const brandName = landing.brand?.brandName ?? 'Dococo Landing Template';
const teacherName = landing.brand?.teacherName ?? '';
const headlineData = landing.hero?.headline;
const renderedHeadlineLines =
  typeof headlineData === 'object' && headlineData?.lines?.length
    ? headlineData.lines.filter(Boolean)
    : [typeof headlineData === 'string' && headlineData.trim() ? headlineData.trim() : brandName];
const leadHeadlinePrefix =
  typeof headlineData === 'object' ? headlineData.lead?.prefix?.trim() ?? '' : '';
const leadHeadlineEmphasis =
  typeof headlineData === 'object' ? headlineData.lead?.emphasis?.trim() ?? '' : '';
const heroImage = landing.hero?.image;
const imageAlt = teacherName ? `${teacherName} 강사 프로필 이미지` : `${brandName} 대표 이미지`;
---

<SectionShell
  id={section.id}
  kind={section.kind}
  class="hero-section"
  surfaceClass="hero-section__surface"
>
  <Container class="hero-section__container">
    <div class="hero-section__grid">
      <div class="hero-section__content">
        <div class="hero-section__headline-stack">
          <h1 class="hero-section__headline">
            {renderedHeadlineLines.map((part, index) => (
              <span class:list={['hero-section__headline-line', index === renderedHeadlineLines.length - 1 && 'is-accent']}>
                {part}
              </span>
            ))}
          </h1>
          {leadHeadlinePrefix || leadHeadlineEmphasis ? (
            <p class="hero-section__headline hero-section__headline--lead-block">
              {leadHeadlinePrefix ? (
                <span class="hero-section__headline-line hero-section__headline-line--lead hero-section__headline-prefix">
                  {leadHeadlinePrefix}
                </span>
              ) : null}
              {leadHeadlineEmphasis ? (
                <span class="hero-section__headline-line hero-section__headline-line--lead hero-section__headline-emphasis">
                  {leadHeadlineEmphasis}
                </span>
              ) : null}
            </p>
          ) : null}
        </div>
      </div>

      <div class="hero-section__visual" aria-hidden={heroImage ? undefined : 'true'}>
        <div class="hero-section__visual-glow"></div>
        <HeroImage src={heroImage} alt={imageAlt} class="hero-section__portrait" />
      </div>
    </div>
  </Container>
</SectionShell>
